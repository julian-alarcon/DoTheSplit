# Copy to .env and fill in. Do NOT commit .env.

# Postgres
POSTGRES_USER=dts
POSTGRES_PASSWORD=dts
POSTGRES_DB=dts
DATABASE_URL=postgres://dts:dts@postgres:5432/dts?sslmode=disable

# API
API_HTTP_ADDR=:8080
WEB_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# Cookies / sessions
# LAN profile: HTTP only, so Secure must be false. See README for the HTTPS deviation.
COOKIE_SECURE=false
SESSION_COOKIE_DOMAIN=

# Email encryption / hashing keys (base64-encoded 32-byte keys).
# Generate with: openssl rand -base64 32
EMAIL_ENC_KEY=
EMAIL_HMAC_KEY=
PASSWORD_PEPPER=

# Web
PUBLIC_API_BASE_URL=http://localhost:8080
API_BASE_URL_INTERNAL=http://api:8080
