# Copy to .env and fill in. Do NOT commit .env.
#
# ---------------------------------------------------------------------------
# Critical secrets: generate ONCE, then back them up safely.
# ---------------------------------------------------------------------------
# These four keys protect every email and password in the database, and sign
# the bearer access tokens used by the SPA / native clients. If you lose them
# you cannot recover your data (and all token sessions are invalidated); if
# they leak an attacker can decrypt every email, forge password hashes, and
# mint valid access tokens.
#
# Generate each one with:
#
#   openssl rand -base64 32
#
# Paste each output below. They MUST stay the same across container rebuilds
# and host reinstalls - store a copy in your password manager or backup vault.
EMAIL_ENC_KEY=
EMAIL_HMAC_KEY=
PASSWORD_PEPPER=
# Signs JWT access tokens (HS256). Rotating it logs out every token client.
JWT_SIGNING_KEY=

# Postgres password. Generate with `openssl rand -base64 24` or pick something
# strong. Resettable later (you can rotate it) but the database has to be
# reachable to do so, so don't lose this one either.
POSTGRES_PASSWORD=

# ---------------------------------------------------------------------------
# Connection settings: adjust if you move services to other hosts.
# ---------------------------------------------------------------------------
POSTGRES_USER=dts
POSTGRES_DB=dts
DATABASE_URL=postgres://dts:CHANGE_ME@postgres:5432/dts?sslmode=disable

# API
API_HTTP_ADDR=:8080
WEB_ORIGIN=http://localhost:3000
LOG_LEVEL=info
# Comma-separated proxy IPs/CIDRs whose X-Forwarded-For is trusted for client
# IP (rate limiting + audit logs). Empty = trust none (use the direct
# connection). Set this only if the API sits behind a reverse proxy you
# control; otherwise a client could forge X-Forwarded-For to dodge rate limits.
TRUSTED_PROXIES=

# Cookies / sessions
# LAN profile: HTTP only, so Secure must be false. See README for the HTTPS deviation.
COOKIE_SECURE=false
SESSION_COOKIE_DOMAIN=

# Web
PUBLIC_API_BASE_URL=http://localhost:8080
API_BASE_URL_INTERNAL=http://api:8080
