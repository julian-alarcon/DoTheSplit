---
// Admin "reset another user's password" modal. Two-field variant of the
// step-up dialog: collects the new password the admin wants to set + the
// admin's own password (step-up). Same wiring contract as ConfirmDialog and
// PasswordPromptDialog: a trigger button inside a <form> with
// `data-reset-open={id}`. The script copies both values into hidden fields
// (`new_password`, `password`) on the form, then requestSubmit().
//
// All dynamic logic lives in web/src/scripts/admin-reset-password.ts.
import FaIcon from "@/components/FaIcon.astro";

interface Props {
  id: string;
  title: string;
  message: string;
  confirmLabel?: string;
  cancelLabel?: string;
}

const {
  id,
  title,
  message,
  confirmLabel = "Reset password",
  cancelLabel = "Cancel",
} = Astro.props as Props;

const titleId = `${id}-title`;
const msgId = `${id}-msg`;
const newId = `${id}-new`;
const adminId = `${id}-admin`;
---

<dialog
  id={id}
  data-reset-dialog
  aria-modal="true"
  aria-labelledby={titleId}
  aria-describedby={msgId}
  class="fixed inset-0 m-auto w-[calc(100%-2rem)] max-w-sm rounded-md border border-neutral-200 bg-white p-0 text-neutral-900 shadow-xl backdrop:bg-neutral-900/40 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-100"
>
  <div class="flex flex-col gap-4 p-5">
    <div class="flex items-start justify-between gap-3">
      <h3 id={titleId} class="text-lg font-medium">{title}</h3>
      <button
        type="button"
        data-reset-cancel
        aria-label="Close"
        title="Close"
        class="rounded-md px-2 py-1 text-sm text-neutral-600 hover:bg-neutral-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-neutral-400 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:focus-visible:ring-neutral-500"
      >
        <FaIcon name="xmark" size={14} />
      </button>
    </div>
    <p id={msgId} class="text-sm text-neutral-600 dark:text-neutral-400">{message}</p>
    <label class="field">
      <input
        id={newId}
        data-reset-new
        type="password"
        autocomplete="new-password"
        minlength="10"
        required
        class="field-input"
        placeholder=" "
      />
      <span class="field-label" data-required>New password (min 10 characters)</span>
    </label>
    <label class="field">
      <input
        id={adminId}
        data-reset-admin
        type="password"
        autocomplete="current-password"
        required
        class="field-input"
        placeholder=" "
      />
      <span class="field-label" data-required>Your password (step-up)</span>
    </label>
    <p class="-mt-2 hidden text-sm text-red-700 dark:text-red-400" data-reset-error></p>
    <div class="flex flex-col gap-2 sm:flex-row sm:justify-end">
      <button type="button" data-reset-cancel class="btn-secondary">{cancelLabel}</button>
      <button type="button" data-reset-accept class="btn-primary">{confirmLabel}</button>
    </div>
  </div>
</dialog>
