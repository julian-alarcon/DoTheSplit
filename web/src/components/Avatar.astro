---
/*
 * Compact avatar block. Renders the server-stored 256x256 PNG (which is a
 * nearest-neighbour upscale of the user's 8x8 client-side pixelation) when
 * `hasAvatar` is true, otherwise a square with 1-2 initials derived from
 * the display name.
 *
 * Sizing comes from `.avatar-N` classes in global.css (NOT inline style):
 * the strict CSP emits style hashes, which makes browsers ignore
 * `'unsafe-inline'` for `style="..."` attributes too. Inline-style
 * dimensions and colors get silently dropped at runtime.
 */

interface Props {
  /** Used to fetch the server-stored avatar bitmap when `hasAvatar` is true. */
  userId: string;
  displayName: string;
  hasAvatar?: boolean;
  avatarUpdatedAt?: string | null;
  /** Side length in CSS pixels. Must be one of the values backed by an
      `.avatar-N` class in global.css. */
  size?: 12 | 16 | 18 | 20 | 24 | 32 | 48 | 56 | 64;
  /** When true, draw a 1px panel-tone border on both branches so the image
      and the initials fallback have an identical outer footprint. */
  bordered?: boolean;
  class?: string;
}

const { userId, displayName, hasAvatar, avatarUpdatedAt, size = 24, bordered = false, class: extraClass = "" } = Astro.props;
const borderClass = bordered ? "border border-neutral-300 dark:border-neutral-700" : "";
const sizeClass = `avatar-${size}`;

/** First letters of up to two name parts, upper-cased. */
function initialsOf(name: string): string {
  const parts = name.trim().split(/\s+/).filter(Boolean);
  if (parts.length >= 2) return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
  if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
  return "??";
}

const initials = initialsOf(displayName);
// Cache-bust avatar URL on every upload.
const avatarSrc = hasAvatar
  ? `/api/user-avatar?id=${encodeURIComponent(userId)}&v=${encodeURIComponent(avatarUpdatedAt ?? "")}`
  : null;
---

{
  avatarSrc ? (
    <img
      src={avatarSrc}
      alt=""
      width={size}
      height={size}
      class={`avatar ${sizeClass} inline-block shrink-0 rounded align-middle ${borderClass} ${extraClass}`}
    />
  ) : (
    <span
      role="img"
      aria-label={displayName}
      class={`avatar ${sizeClass} inline-flex shrink-0 items-center justify-center rounded align-middle font-semibold leading-none ${borderClass} ${extraClass}`}
    >
      {initials}
    </span>
  )
}
