---
/*
 * Compact avatar block. Renders the server-stored 256x256 PNG (which is a
 * nearest-neighbour upscale of the user's 8x8 client-side pixelation) when
 * `hasAvatar` is true, otherwise a deterministic colored square with 1-2
 * initials derived from the display name.
 *
 * The stored bitmap is already blocky, so the browser only down-scales to the
 * target size and no `image-rendering` hints are needed.
 */

interface Props {
  userId: string;
  displayName: string;
  hasAvatar?: boolean;
  avatarUpdatedAt?: string | null;
  /** Side length in CSS pixels. Default 24px (matches inline text size). */
  size?: number;
  class?: string;
}

const { userId, displayName, hasAvatar, avatarUpdatedAt, size = 24, class: extraClass = "" } = Astro.props;

/** First letters of up to two name parts, upper-cased. */
function initialsOf(name: string): string {
  const parts = name.trim().split(/\s+/).filter(Boolean);
  if (parts.length >= 2) return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
  if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
  return "??";
}

/** Deterministic hsl color derived from the user UUID - every user is stable + distinct. */
function colorOf(id: string): string {
  let h = 0;
  for (let i = 0; i < id.length; i++) h = (h * 31 + id.charCodeAt(i)) >>> 0;
  return `hsl(${h % 360}, 65%, 45%)`;
}

const initials = initialsOf(displayName);
const fallbackBg = colorOf(userId);
// Cache-bust avatar URL on every upload.
const avatarSrc = hasAvatar
  ? `/api/user-avatar?id=${encodeURIComponent(userId)}&v=${encodeURIComponent(avatarUpdatedAt ?? "")}`
  : null;
const fontPx = Math.max(10, Math.round(size * 0.45));
---

{
  avatarSrc ? (
    <img
      src={avatarSrc}
      alt=""
      width={size}
      height={size}
      style={`width:${size}px;height:${size}px;`}
      class={`inline-block shrink-0 rounded align-middle ${extraClass}`}
    />
  ) : (
    <span
      role="img"
      aria-label={displayName}
      style={`width:${size}px;height:${size}px;background-color:${fallbackBg};font-size:${fontPx}px;`}
      class={`inline-flex shrink-0 items-center justify-center rounded align-middle font-semibold leading-none text-white ${extraClass}`}
    >
      {initials}
    </span>
  )
}
