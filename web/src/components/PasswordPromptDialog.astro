---
// Step-up password modal for destructive admin actions. Same wiring contract
// as ConfirmDialog, with one extra step: the user types their own password
// into the modal, the script copies it into a hidden `password` field on the
// trigger's form, and only then submits.
//
// Usage:
//   <button type="button" data-password-open={id}>Delete user</button>
// inside a <form>. The form should NOT carry a `password` field of its own;
// the script injects (or replaces) one before submitting.
//
// All dynamic logic lives in web/src/scripts/password-prompt.ts.
import FaIcon from "@/components/FaIcon.astro";

interface Props {
  id: string;
  title: string;
  message: string;
  confirmLabel: string;
  // "danger" → red filled button; "primary" → black/white filled.
  confirmVariant?: "danger" | "primary";
  cancelLabel?: string;
  // Optional Font Awesome glyph mirrored on the modal's accept button so the
  // visual identity matches the trigger that opened it.
  confirmIcon?: string;
}

const {
  id,
  title,
  message,
  confirmLabel,
  confirmVariant = "danger",
  cancelLabel = "Cancel",
  confirmIcon,
} = Astro.props as Props;

const titleId = `${id}-title`;
const msgId = `${id}-msg`;
const inputId = `${id}-pw`;

const confirmCls = confirmVariant === "danger" ? "btn-danger" : "btn-primary";
---

<dialog
  id={id}
  data-password-dialog
  aria-modal="true"
  aria-labelledby={titleId}
  aria-describedby={msgId}
  class="fixed inset-0 m-auto w-[calc(100%-2rem)] max-w-sm rounded-md border border-neutral-200 bg-white p-0 text-neutral-900 shadow-xl backdrop:bg-neutral-900/40 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-100"
>
  <div class="flex flex-col gap-4 p-5">
    <div class="flex items-start justify-between gap-3">
      <h3 id={titleId} class="text-lg font-medium">{title}</h3>
      <button
        type="button"
        data-password-cancel
        aria-label="Close"
        title="Close"
        class="rounded-md px-2 py-1 text-sm text-neutral-600 hover:bg-neutral-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-neutral-400 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:focus-visible:ring-neutral-500"
      >
        <FaIcon name="xmark" size={14} />
      </button>
    </div>
    <p id={msgId} class="text-sm text-neutral-600 dark:text-neutral-400">{message}</p>
    <label class="field">
      <input
        id={inputId}
        data-password-input
        type="password"
        autocomplete="current-password"
        required
        class="field-input"
        placeholder=" "
      />
      <span class="field-label" data-required>Your password</span>
    </label>
    <p class="-mt-2 hidden text-sm text-red-700 dark:text-red-400" data-password-error>
      Password is required.
    </p>
    <div class="flex flex-col gap-2 sm:flex-row sm:justify-end">
      <button type="button" data-password-cancel class="btn-secondary">{cancelLabel}</button>
      <button type="button" data-password-accept class={confirmCls}>
        {confirmIcon && <FaIcon name={confirmIcon} />}
        <span>{confirmLabel}</span>
      </button>
    </div>
  </div>
</dialog>
