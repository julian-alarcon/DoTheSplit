---
// Theme picker. Per-device only - value lives in localStorage (key:
// dts_theme) and never leaves the browser. Default is "dark". Rendered as a
// native radio group styled as a 3-state segmented switch; theme-switcher.ts
// checks the stored option on load and writes localStorage on change.
import FaIcon from "@/components/FaIcon.astro";
const options = [
  { value: "dark", label: "Dark", icon: "moon" },
  { value: "light", label: "Light", icon: "sun" },
  { value: "high-contrast", label: "High contrast", icon: "circle-half-stroke" },
] as const;
---

<fieldset class="theme-seg" data-theme-picker>
  <legend class="sr-only">Theme</legend>
  {
    options.map((opt) => (
      <label class="theme-seg-opt" title={opt.label}>
        <input type="radio" name="theme" value={opt.value} />
        <span class="theme-seg-icon"><FaIcon name={opt.icon} /></span>
        <span class="sr-only">{opt.label}</span>
      </label>
    ))
  }
</fieldset>
<script src="/src/scripts/theme-switcher.ts"></script>
