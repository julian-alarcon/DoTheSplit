---
import Base from "@/layouts/Base.astro";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");
// Already in good standing? Skip the gate.
if (!user.must_change_password) return Astro.redirect("/groups");

const err = Astro.url.searchParams.get("error");
---

<Base title="Change your password">
  <h1 class="text-2xl font-semibold mb-2">Change your password</h1>
  <p class="text-sm text-neutral-700 dark:text-neutral-300 mb-4">
    An administrator reset your password. Pick a new one to continue using DoTheSplit.
  </p>

  {err === "wrong" && <p class="rounded bg-red-50 px-3 py-2 text-sm text-red-800 mb-4 dark:bg-red-950 dark:text-red-200">Could not change your password. Check the temporary password your administrator gave you.</p>}
  {err === "invalid" && <p class="rounded bg-red-50 px-3 py-2 text-sm text-red-800 mb-4 dark:bg-red-950 dark:text-red-200">New password must be at least 10 characters.</p>}

  <form method="POST" action="/api/me-password-force" class="grid gap-3 max-w-md">
    <label class="field">
      <input name="old_password" type="password" autocomplete="current-password" required class="field-input" placeholder=" " />
      <span class="field-label" data-required>Temporary password</span>
    </label>
    <p class="field-error">Required</p>

    <label class="field">
      <input name="new_password" type="password" autocomplete="new-password" required minlength="10" class="field-input" placeholder=" " />
      <span class="field-label" data-required>New password (min 10 characters)</span>
    </label>
    <p class="field-error">At least 10 characters</p>

    <button type="submit" class="btn-primary self-start">Change password</button>
  </form>
</Base>
