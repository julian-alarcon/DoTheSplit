---
import Base from "@/layouts/Base.astro";
import { apiFor } from "@/lib/api/client";

const user = Astro.locals.user;
if (!user || !user.is_admin) return Astro.redirect("/groups");

const cookie = Astro.locals.cookie ?? "";
const api = apiFor(cookie);

const offset = parseInt(Astro.url.searchParams.get("offset") ?? "0", 10) || 0;
const limit = 50;
const action = Astro.url.searchParams.get("action") ?? "";

const { data, error } = await api.GET("/v1/admin/audit", {
  params: { query: { limit, offset, action: action || undefined } },
});

const items = data?.items ?? [];
const total = data?.total ?? 0;

function fmtTs(s: string) {
  return new Date(s).toISOString().replace("T", " ").slice(0, 19) + "Z";
}
---

<Base title="Admin · Audit" back={{ href: "/admin", label: "Admin" }}>
  <h1 class="text-2xl font-semibold mb-4">Audit log ({total})</h1>

  {error && <p class="rounded bg-red-50 px-3 py-2 text-sm text-red-800 mb-4 dark:bg-red-950 dark:text-red-200">Could not load audit entries.</p>}

  <form method="GET" class="mb-4 flex flex-wrap items-center gap-2">
    <label class="text-sm">Action</label>
    <input name="action" value={action} placeholder="e.g. admin_delete_user" class="rounded border border-neutral-300 bg-white px-2 py-1 text-sm dark:border-neutral-700 dark:bg-neutral-900" />
    <button type="submit" class="btn-secondary btn-sm">Filter</button>
  </form>

  <ul class="grid gap-2">
    {items.map((e) => (
      <li class:list={["rounded border p-3 text-sm", e.success ? "border-neutral-200 dark:border-neutral-800" : "border-red-300 bg-red-50 dark:border-red-900 dark:bg-red-950/30"]}>
        <div class="flex flex-wrap items-center gap-2">
          <code class="rounded bg-neutral-100 px-1.5 py-0.5 text-xs dark:bg-neutral-800">{e.action}</code>
          <span class="text-xs text-neutral-500">{fmtTs(e.created_at)}</span>
          {!e.success && <span class="text-xs font-medium text-red-700 dark:text-red-400">FAILED</span>}
        </div>
        <div class="mt-1 text-xs text-neutral-600 dark:text-neutral-400">
          actor <code>{e.actor_user_id.slice(0, 8)}</code>
          {e.target_user_id && <> · target user <code>{e.target_user_id.slice(0, 8)}</code></>}
          {e.target_group_id && <> · target group <code>{e.target_group_id.slice(0, 8)}</code></>}
          {e.ip && <> · ip {e.ip}</>}
        </div>
        {e.metadata && (
          <pre class="mt-2 overflow-x-auto rounded bg-neutral-50 p-2 text-xs dark:bg-neutral-900">{JSON.stringify(e.metadata, null, 2)}</pre>
        )}
      </li>
    ))}
  </ul>
  <nav class="mt-4 flex gap-2 text-sm">
    {offset > 0 && <a class="hover:underline" href={`/admin/audit?offset=${Math.max(0, offset - limit)}${action ? `&action=${encodeURIComponent(action)}` : ""}`}>← Previous</a>}
    {offset + limit < total && <a class="hover:underline" href={`/admin/audit?offset=${offset + limit}${action ? `&action=${encodeURIComponent(action)}` : ""}`}>Next →</a>}
  </nav>
</Base>
