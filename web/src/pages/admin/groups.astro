---
import Base from "@/layouts/Base.astro";
import FaIcon from "@/components/FaIcon.astro";
import PasswordPromptDialog from "@/components/PasswordPromptDialog.astro";
import { apiFor } from "@/lib/api/client";

const user = Astro.locals.user;
if (!user || !user.is_admin) return Astro.redirect("/groups");

const cookie = Astro.locals.cookie ?? "";
const api = apiFor(cookie);

const offset = parseInt(Astro.url.searchParams.get("offset") ?? "0", 10) || 0;
const limit = 50;

const { data, error } = await api.GET("/v1/admin/groups", {
  params: { query: { limit, offset } },
});

const items = data?.items ?? [];
const total = data?.total ?? 0;

const deleted = Astro.url.searchParams.get("deleted");
const deleteErr = Astro.url.searchParams.get("delete_error");

function fmtDate(s: string) {
  return new Date(s).toISOString().slice(0, 10);
}
---

<Base title="Admin · Groups" back={{ href: "/admin", label: "Admin" }}>
  <h1 class="text-2xl font-semibold mb-4">All groups ({total})</h1>

  {error && <p class="rounded bg-red-50 px-3 py-2 text-sm text-red-800 mb-4 dark:bg-red-950 dark:text-red-200">Could not load groups.</p>}
  {deleted && <p class="rounded bg-green-50 px-3 py-2 text-sm text-green-800 mb-4 dark:bg-green-950 dark:text-green-200">Group deleted.</p>}
  {deleteErr === "step_up" && <p class="rounded bg-red-50 px-3 py-2 text-sm text-red-800 mb-4 dark:bg-red-950 dark:text-red-200">Step-up password did not match.</p>}
  {deleteErr === "locked" && <p class="rounded bg-red-50 px-3 py-2 text-sm text-red-800 mb-4 dark:bg-red-950 dark:text-red-200">Too many failed step-up attempts; wait a minute.</p>}
  {deleteErr && !["step_up","locked"].includes(deleteErr) && <p class="rounded bg-red-50 px-3 py-2 text-sm text-red-800 mb-4 dark:bg-red-950 dark:text-red-200">Delete failed.</p>}

  <ul class="grid gap-2">
    {items.map((g) => (
      <li class="rounded-md border border-neutral-200 bg-white p-3 dark:border-neutral-800 dark:bg-neutral-900">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div class="min-w-0">
            <div class="font-medium truncate">
              <a href={`/groups/${g.id}`} class="hover:underline">{g.name}</a>
            </div>
            <div class="text-xs text-neutral-600 dark:text-neutral-400">
              {g.member_count} members · {g.expense_count} expenses · {g.default_currency} · created {fmtDate(g.created_at)}
            </div>
          </div>
          <form method="POST" action="/api/admin/group-delete" class="contents">
            <input type="hidden" name="id" value={g.id} />
            <button type="button" data-password-open="dlg-delete-group" class="btn-danger btn-sm ml-auto">
              <FaIcon name="trash" />
              <span>Delete</span>
            </button>
          </form>
        </div>
      </li>
    ))}
  </ul>
  <nav class="mt-4 flex gap-2 text-sm">
    {offset > 0 && <a class="hover:underline" href={`/admin/groups?offset=${Math.max(0, offset - limit)}`}>← Previous</a>}
    {offset + limit < total && <a class="hover:underline" href={`/admin/groups?offset=${offset + limit}`}>Next →</a>}
  </nav>

  <PasswordPromptDialog
    id="dlg-delete-group"
    title="Delete this group?"
    message="This permanently removes the group along with every expense, settlement, and recurring template it contains. Members keep their accounts. Re-enter your password to confirm."
    confirmLabel="Delete group"
    confirmVariant="danger"
    confirmIcon="trash"
  />

  <script>
    import "@/scripts/password-prompt.ts";
  </script>
</Base>
