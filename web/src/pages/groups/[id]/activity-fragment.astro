---
// Server-rendered HTML fragment for the activity Load-more island. Returns a
// list of <li> rows + a hidden div carrying the next cursor, no document shell.
// activity-load-more.ts fetches this URL as text and appends the rows.
//
// Render-only: no auth or 404 redirects (the API call already enforces that).
import ActivityRow from "@/components/ActivityRow.astro";
import { apiFor } from "@/lib/api/client";

const { id } = Astro.params as { id: string };
const cursor = Astro.url.searchParams.get("cursor") ?? "";
const limit = Astro.url.searchParams.get("limit") ?? "50";

const api = apiFor(Astro.locals.cookie);
const [groupsRes, activityRes] = await Promise.all([
  api.GET("/v1/groups"),
  api.GET("/v1/groups/{id}/activity", {
    params: { path: { id }, query: { cursor: cursor || undefined, limit: Number(limit) } },
  }),
]);
const items = activityRes.data?.items ?? [];
const nextCursor = activityRes.data?.next_cursor ?? "";
const viewerID = Astro.locals.user?.id ?? "";
const members = groupsRes.data?.find((g) => g.id === id)?.members ?? [];
---
{items.map((item) => (
  <ActivityRow item={item} groupId={id} viewerId={viewerID} members={members} locale={Astro.locals.locale} />
))}
<div data-activity-next-cursor={nextCursor} hidden></div>
