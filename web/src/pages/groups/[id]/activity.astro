---
import Base from "@/layouts/Base.astro";
import ActivityRow from "@/components/ActivityRow.astro";
import { apiFor } from "@/lib/api/client";

const { id } = Astro.params as { id: string };
const api = apiFor(Astro.locals.cookie);

const [groupsRes, activityRes] = await Promise.all([
  api.GET("/v1/groups"),
  api.GET("/v1/groups/{id}/activity", { params: { path: { id } } }),
]);

const group = groupsRes.data?.find((g) => g.id === id);
if (!group) {
  return Astro.redirect("/groups");
}
const items = activityRes.data?.items ?? [];
const nextCursor = activityRes.data?.next_cursor ?? "";
const viewerID = Astro.locals.user?.id ?? "";
---

<Base title={`${group.name} - activity`} back={{ href: `/groups/${id}`, label: group.name }}>
  <h1 class="mb-4 text-2xl font-semibold">Activity</h1>
  {items.length === 0 ? (
    <p class="text-sm text-neutral-500">No activity yet.</p>
  ) : (
    <ul class="divide-y divide-neutral-200 dark:divide-neutral-800" data-activity-list>
      {items.map((item) => (
        <ActivityRow item={item} groupId={id} viewerId={viewerID} locale={Astro.locals.locale} />
      ))}
    </ul>
  )}
  {nextCursor && (
    <div class="mt-4 flex justify-center">
      <button
        type="button"
        data-activity-load-more
        data-group-id={id}
        data-cursor={nextCursor}
        class="btn-secondary btn-sm"
      >
        Load more
      </button>
    </div>
  )}

  <script>
    import "@/scripts/activity-load-more.ts";
  </script>
</Base>
