---
import Base from "@/layouts/Base.astro";
import { apiFor } from "@/lib/api/client";

const { id } = Astro.params as { id: string };
const api = apiFor(Astro.locals.cookie);

const groupsRes = await api.GET("/v1/groups");
const group = groupsRes.data?.find((g) => g.id === id);
if (!group) {
  return Astro.redirect("/groups");
}

const errorCode = Astro.url.searchParams.get("error") ?? "";
const isPair = group.members.length === 2;
const hasDefaultSplit = (group.default_split?.length ?? 0) === 2;
const splitMode =
  isPair && hasDefaultSplit
    ? "Pinned percentage split"
    : `Equal split across all ${group.members.length} members`;
---

<Base
  title={`${group.name} - import expenses`}
  back={{ href: `/groups/${id}/settings`, label: "Settings" }}
>
  <h1 class="mb-2 text-2xl font-semibold">Import expenses</h1>
  <p class="mb-4 text-sm text-neutral-600 dark:text-neutral-400">
    Append expenses to <span class="font-medium">{group.name}</span> from a
    DoTheSplit-shaped CSV. Splits will use this group's rule:
    <span class="font-medium">{splitMode}</span>.
  </p>
  <p class="mb-6 text-sm text-neutral-600 dark:text-neutral-400">
    Required per row: <code>Date</code>, <code>Description</code>,
    <code>Cost</code>. Other columns are optional. Empty cells fall back to
    the group currency ({group.default_currency}), the importer as payer,
    and the <code>other</code> category. The optional <code>Payer</code>
    column matches a member's display name; an unknown name causes the
    row to be skipped.
  </p>

  {errorCode && (
    <p
      role="alert"
      class="mb-4 rounded-md border border-red-300 bg-red-50 px-3 py-2 text-sm text-red-900 dark:border-red-900 dark:bg-red-950 dark:text-red-200"
    >
      Import failed: <code>{errorCode}</code>. Try again or check the file.
    </p>
  )}

  {/* Phase 1: file picker. */}
  <section
    id="phase-pick"
    class="rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900"
  >
    <form id="csv-pick-form" class="flex flex-col gap-3">
      <label class="field">
        <input
          id="csv-file"
          name="csv_file"
          type="file"
          accept=".csv,text/csv"
          required
          class="field-input file:mr-3 file:rounded-sm file:border-0 file:bg-neutral-100 file:px-3 file:py-1 file:text-sm dark:file:bg-neutral-800"
        />
        <span class="field-label" data-required>CSV file</span>
      </label>
      <p class="field-error">Pick a DoTheSplit-shaped CSV (.csv, max 256 KiB).</p>
      <p
        id="csv-pick-error"
        class="hidden text-sm text-red-600 dark:text-red-400"
        role="alert"
      ></p>
      <button type="submit" class="btn-primary mt-2 self-end">Next</button>
    </form>
  </section>

  {/* Phase 2: preview + confirm. Hidden until phase 1 succeeds. */}
  <section id="phase-review" class="mt-4 hidden flex-col gap-4">
    <form
      id="csv-import-form"
      method="POST"
      action={`/api/group-expenses-import?id=${id}`}
      class="flex flex-col gap-3 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900"
    >
      <input type="hidden" id="csv-text" name="csv" value="" />

      <input
        type="hidden"
        id="group-currency"
        value={group.default_currency}
      />

      <div
        id="currency-mixed-warning"
        class="hidden rounded-md border border-amber-300 bg-amber-50 p-3 text-sm text-amber-900 dark:border-amber-700 dark:bg-amber-950/40 dark:text-amber-200"
        role="alert"
      >
        <p class="font-medium">This CSV mixes multiple currencies</p>
        <p class="mt-1">
          DoTheSplit groups are single-currency. The imported amounts will be
          stored under the group's currency ({group.default_currency}) regardless
          of what the CSV says. Detected:
          <span id="currency-mixed-list" class="font-mono"></span>.
        </p>
      </div>

      <div class="rounded-md border border-neutral-200 p-3 text-sm dark:border-neutral-800">
        <div class="mb-2 flex items-center justify-between">
          <span class="font-medium">Expenses preview</span>
          <span id="counts" class="text-xs text-neutral-600 dark:text-neutral-400"></span>
        </div>
        <ul id="preview-list" class="flex flex-col gap-2"></ul>
        <p
          id="preview-more"
          class="mt-2 hidden text-xs text-neutral-600 dark:text-neutral-400"
        ></p>
      </div>

      <details
        id="skipped-section"
        class="hidden rounded-md border border-neutral-200 p-3 text-sm dark:border-neutral-800"
      >
        <summary class="cursor-pointer font-medium">
          Skipped rows
          <span
            id="skipped-counter"
            class="text-xs font-normal text-neutral-600 dark:text-neutral-400"
          ></span>
        </summary>
        <p class="mt-2 text-xs text-neutral-600 dark:text-neutral-400">
          Rows the importer dropped (bad date, missing cost, unknown payer
          name, etc.) shown verbatim:
        </p>
        <pre
          id="skipped-list"
          class="mt-2 max-h-64 overflow-auto rounded-sm bg-neutral-50 p-2 font-mono text-xs leading-relaxed dark:bg-neutral-950"
        ></pre>
        <p
          id="skipped-more"
          class="mt-2 hidden text-xs text-neutral-600 dark:text-neutral-400"
        ></p>
      </details>

      <div class="mt-2 flex items-center justify-between gap-3">
        <button type="button" id="phase-back" class="btn-secondary btn-sm">
          Pick another file
        </button>
        <button type="submit" class="btn-primary">Import</button>
      </div>
    </form>
  </section>

  <script src="/src/scripts/import-group-expenses.ts"></script>
</Base>
