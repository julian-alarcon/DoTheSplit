---
import Base from "@/layouts/Base.astro";
import Avatar from "@/components/Avatar.astro";
import { apiFor } from "@/lib/api/client";

const { id } = Astro.params as { id: string };
const api = apiFor(Astro.locals.cookie);

const { data: groups } = await api.GET("/v1/groups");
const group = groups?.find((g) => g.id === id);
if (!group) return Astro.redirect("/groups");

const currency = group.default_currency;
const me = Astro.locals.user;
const members = group.members;
const showError = Astro.url.searchParams.get("error") === "1";
---

<Base title={`Settle up · ${group.name}`} back={{ href: `/groups/${id}`, label: group.name }}>
  <div class="mx-auto flex max-w-xl flex-col gap-6">
    <div>
      <h1 class="text-2xl font-semibold">Settle up</h1>
      <p class="text-sm text-neutral-600 dark:text-neutral-400">Record a payment between two members of {group.name}.</p>
    </div>

    {showError && (
      <p
        role="status"
        aria-live="polite"
        class="rounded-md border border-red-300 bg-red-50 px-3 py-2 text-sm text-red-900 dark:border-red-900 dark:bg-red-950 dark:text-red-200"
      >
        Could not record the settlement. Check the payer, recipient, and amount and try again.
      </p>
    )}

    {members.length < 2 ? (
      <p class="rounded-md border border-neutral-200 bg-white p-4 text-sm text-neutral-600 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-400">
        This group needs at least two members before anyone can settle up. Add someone under
        <a href={`/groups/${id}/settings`} class="underline"> Group settings</a>.
      </p>
    ) : (
      <form
        method="POST"
        action={`/api/settlements?id=${id}`}
        class="flex flex-col gap-4 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900"
      >
        <label class="field-select-row">
          <span>Paid by <span class="text-red-600">*</span></span>
          <select name="from_user_id" required class="field-select">
            {members.map((m) => (
              <option value={m.user_id} selected={m.user_id === me?.id}>{m.display_name}</option>
            ))}
          </select>
        </label>

        <label class="field-select-row">
          <span>Paid to <span class="text-red-600">*</span></span>
          <select name="to_user_id" required class="field-select">
            <option value="">Pick a member…</option>
            {members.map((m) => (
              <option value={m.user_id}>{m.display_name}</option>
            ))}
          </select>
        </label>

        <label class="field">
          <input type="hidden" name="amount_dollars" />
          <input
            type="text"
            inputmode="decimal"
            data-currency-input
            data-currency-hidden="amount_dollars"
            data-currency={currency}
            required
            placeholder=" "
            class="field-input field-input-currency"
          />
          <span class="field-label" data-required>Amount ({currency})</span>
        </label>
        <p class="field-error">Enter an amount greater than 0</p>

        <div class="flex items-center justify-end gap-2">
          <a href={`/groups/${id}`} class="btn-secondary">Cancel</a>
          <button type="submit" class="btn-primary">Record payment</button>
        </div>
      </form>
    )}

    <section class="rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
      <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-neutral-600 dark:text-neutral-400">Group members</h2>
      <ul class="flex flex-col gap-2 text-sm">
        {members.map((m) => (
          <li class="flex items-center gap-2">
            <Avatar
              userId={m.user_id}
              displayName={m.display_name}
              hasAvatar={m.has_avatar}
              avatarUpdatedAt={m.avatar_updated_at}
              size={20}
            />
            <span>{m.display_name}</span>
          </li>
        ))}
      </ul>
    </section>
  </div>

  <script>
    import "@/scripts/currency-input.ts";
  </script>
</Base>
