---
import Base from "@/layouts/Base.astro";
import { apiFor } from "@/lib/api/client";

const api = apiFor(Astro.locals.cookie);
const { data: groups = [] } = await api.GET("/v1/groups");
---

<Base title="Groups">
  <div class="mb-4 flex items-center justify-between">
    <h1 class="text-2xl font-semibold">Your groups</h1>
    <a href="/groups/new" class="rounded-md bg-neutral-900 px-3 py-1.5 text-sm font-medium text-white hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900">
      New group
    </a>
  </div>

  {groups.length === 0 ? (
    <p class="text-neutral-600 dark:text-neutral-400">
      No groups yet. <a href="/groups/new" class="underline">Create one</a>.
    </p>
  ) : (
    <ul class="flex flex-col gap-2">
      {groups.map((g) => (
        <li>
          <a href={`/groups/${g.id}`} class="flex items-center justify-between rounded-md border border-neutral-200 bg-white px-4 py-3 hover:bg-neutral-50 dark:border-neutral-800 dark:bg-neutral-900 dark:hover:bg-neutral-800">
            <span class="font-medium">{g.name}</span>
            <span class="text-sm text-neutral-500">
              {g.members.length} member{g.members.length === 1 ? "" : "s"} · {g.default_currency}
            </span>
          </a>
        </li>
      ))}
    </ul>
  )}
</Base>
