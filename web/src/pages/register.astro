---
import Base from "@/layouts/Base.astro";
const showError = Astro.url.searchParams.get("error") === "1";
---

<Base title="Register">
  <div class="mx-auto max-w-sm">
    <h1 class="mb-6 text-2xl font-semibold">Create account</h1>
    {showError && (
      <p class="mb-4 rounded-md border border-red-300 bg-red-50 px-3 py-2 text-sm text-red-900 dark:border-red-900 dark:bg-red-950 dark:text-red-200">
        Could not register. The email may already be in use.
      </p>
    )}
    <form method="POST" action="/api/register" class="flex flex-col gap-3">
      <label class="flex flex-col gap-1 text-sm">
        <span>Display name</span>
        <input name="display_name" required maxlength="80" class="rounded-md border border-neutral-300 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-900" />
      </label>
      <label class="flex flex-col gap-1 text-sm">
        <span>Email</span>
        <input type="email" name="email" required class="rounded-md border border-neutral-300 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-900" />
      </label>
      <label class="flex flex-col gap-1 text-sm">
        <span>Password (min 10 characters)</span>
        <input type="password" name="password" required minlength="10" class="rounded-md border border-neutral-300 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-900" />
      </label>
      <button type="submit" class="mt-2 rounded-md bg-neutral-900 px-4 py-2 text-sm font-medium text-white hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300">
        Create account
      </button>
    </form>
    <p class="mt-4 text-sm text-neutral-600 dark:text-neutral-400">
      Already have one? <a href="/login" class="underline">Log in</a>.
    </p>
  </div>
</Base>
