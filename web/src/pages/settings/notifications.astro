---
import Base from "@/layouts/Base.astro";
import { apiFor } from "@/lib/api/client";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

// Server-render the current values via the typed client. Soft-fail: when the
// API errors, `data` is undefined and the form renders with defaults.
const api = apiFor(Astro.locals.cookie);
const { data } = await api.GET("/v1/me/notifications");
const prefs = data ?? {};

const ok = Astro.url.searchParams.get("ok");
---

<Base title="Notifications" back={{ href: "/settings", label: "Settings" }}>
  <div class="mx-auto flex max-w-xl flex-col gap-3">
    <h1 class="text-2xl font-semibold">Notifications</h1>
    <p class="text-sm text-neutral-600 dark:text-neutral-400">
      Pick what should reach you. Defaults are off - opt in to anything you want to hear about.
    </p>

    {ok === "saved" && (
      <p
        role="status"
        aria-live="polite"
        class="rounded-md border border-emerald-300 bg-emerald-50 px-3 py-2 text-sm text-emerald-900 dark:border-emerald-900 dark:bg-emerald-950 dark:text-emerald-200"
      >
        Preferences saved.
      </p>
    )}

    <form
      method="POST"
      action="/api/me-notifications"
      class="flex flex-col gap-4 rounded-md border border-neutral-200 bg-white p-3 dark:border-neutral-800 dark:bg-neutral-900"
    >
      <h2 class="text-sm font-medium uppercase tracking-wide text-neutral-600 dark:text-neutral-400">
        Email
      </h2>

      <label class="toggle">
        <input
          type="checkbox"
          name="notify_recurring_run"
          value="1"
          class="toggle-input"
          checked={prefs.notify_recurring_run === true}
        />
        <span class="toggle-track" aria-hidden="true"></span>
        <span>A recurring expense is added to one of my groups</span>
      </label>

      <label class="toggle">
        <input
          type="checkbox"
          name="notify_settlement"
          value="1"
          class="toggle-input"
          checked={prefs.notify_settlement === true}
        />
        <span class="toggle-track" aria-hidden="true"></span>
        <span>A settlement is recorded in one of my groups</span>
      </label>

      <label class="toggle">
        <input
          type="checkbox"
          name="notify_group_added"
          value="1"
          class="toggle-input"
          checked={prefs.notify_group_added === true}
        />
        <span class="toggle-track" aria-hidden="true"></span>
        <span>I am added to a new group</span>
      </label>

      <div class="flex justify-end pt-2">
        <button type="submit" class="btn-primary">Save preferences</button>
      </div>
    </form>
  </div>
</Base>
